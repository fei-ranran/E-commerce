<% if (typeof recommendations !== 'undefined' && recommendations && recommendations.length) { %>
  <section class="recommend-section" aria-labelledby="recommend-heading">
    <div class="section-heading wide">
      <div>
        <p class="eyebrow" data-i18n="recommend.forYou"><%= __('recommend.forYou') %></p>
        <h2 id="recommend-heading" data-i18n="recommend.forYou"><%= __('recommend.forYou') %></h2>
      </div>
    </div>
    <div class="recommend-strip" role="list">
      <% recommendations.forEach(function (product) { %>
        <div class="recommend-strip-item" role="listitem">
          <%- include('./product-card', { product }) %>
        </div>
      <% }); %>
    </div>
  </section>
<% } %>
