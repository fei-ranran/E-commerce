<!-- Codex, GPT-5.5 High, OpenAI. -->
<article class="product-card">
  <a class="product-media" href="/products/<%= product._id %>">
    <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
    <span class="condition-badge <%= product.condition === 'used' ? 'used' : 'new' %>" data-i18n="product.condition.<%= product.condition === 'used' ? 'used' : 'new' %>">
      <%= __( 'product.condition.' + (product.condition === 'used' ? 'used' : 'new') ) %>
    </span>
  </a>
  <div class="product-body">
    <div class="product-title-row">
      <h3><a href="/products/<%= product._id %>">
          <%= product.name %>
        </a></h3>
      <strong>¥<%= product.price.toFixed(2) %></strong>
    </div>
    <p>
      <%= product.description %>
    </p>
    <div class="product-meta">
      <span>
        <%= product.category %>
      </span>
      <% var wearLabels = { like_new: '几乎全新', good: '良好', fair: '一般', visible_wear: '明显痕迹' }; %>
      <% if (product.condition === 'used' && product.wearGrade) { %>
        <span class="wear-chip"><%= wearLabels[product.wearGrade] || product.wearGrade %></span>
      <% } %>
      <% if (product.freeShipping) { %>
        <span class="shipping-badge">包邮</span>
      <% } %>
      <% var optimizeTags = ['包邮', '九成新', '成色良好', '正常磨损', '明显使用痕迹', '新品', '低价好物', '高价值']; %>
      <% (product.tags || []).filter(function (tag) { return optimizeTags.indexOf(tag) >= 0; }).slice(0, 2).forEach(function (tag) { %>
        <span class="opt-tag"><%= tag %></span>
      <% }); %>
      <span>已售 <%= product.salesCount != null ? product.salesCount : 0 %></span>
      <span>库存 <%= product.stock %></span>
      <span class="seller-chip"><i></i>
        <%= product.sellerName %>
      </span>
    </div>
    <!-- Antigraity, Gemini 3.1 Pro (high), Google.：库存为0时卡片显示已售罄 -->
      <% if (product.stock> 0) { %>
      <form action="/cart/add/<%= product._id %>" method="POST">
        <button class="button primary full" type="submit" data-i18n="product.addToCart"><%= __('product.addToCart') %></button>
      </form>
      <% } else { %>
        <button class="button ghost full" disabled data-i18n="product.soldOut"><%= __('product.soldOut') %></button>
      <% } %>
          <!-- end: Antigraity, Gemini 3.1 Pro (high), Google. -->
  </div>
</article>
<!-- end: Codex, GPT-5.5 High, OpenAI. -->
