<!-- Codex, GPT-5.5 High, OpenAI. -->
<!DOCTYPE html>
<html lang="zh-CN">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <script src="/js/app.js" defer></script>
</head>

<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a class="brand" href="/">
        <span class="brand-mark">C</span>
        <span>Cream Market</span>
      </a>
      <button class="nav-toggle" type="button" aria-label="打开导航" data-nav-toggle>☰</button>
      <nav class="site-nav" data-nav>
        <a data-i18n="nav.home" class="<%= active === 'home' ? 'active' : '' %>" href="/"><%= __('nav.home') %></a>
        <a data-i18n="nav.second" class="<%= active === 'second' ? 'active' : '' %>" href="/second-hand"><%= __('nav.second') %></a>
        <a data-i18n="nav.cart" class="<%= active === 'cart' ? 'active' : '' %>" href="/cart"><%= __('nav.cart') %></a>
        <a data-i18n="nav.sell" class="<%= active === 'sell' ? 'active' : '' %>" href="/products/new"><%= __('nav.sell') %></a>
        <% if (currentUser) { %>
          <!-- Antigravity, Claude Sonnet 4.6 (thinking), Anthropic. 新增：我的订单导航入口 -->
          <a data-i18n="nav.orders" class="<%= active === 'orders' ? 'active' : '' %>" href="/orders/mine"><%= __('nav.orders') %></a>
          <!-- end: Antigravity, Claude Sonnet 4.6 (thinking), Anthropic. 新增 -->
          <% if (currentUser.role === 'admin' || currentUser.role === 'superadmin') { %>
            <a class="<%= active === 'admin' ? 'active' : '' %>" href="/admin/similarity-settings"><%= __('nav.admin') %></a>
          <% } %>
            <a data-i18n="nav.messages" class="<%= active === 'messages' ? 'active' : '' %>" href="/messages"><%= __('nav.messages') %></a>
            <a data-i18n="nav.favorites" class="<%= active === 'favorites' ? 'active' : '' %>" href="/favorites"><%= __('nav.favorites') %></a>
            <a data-i18n="nav.mine" class="<%= active === 'mine' ? 'active' : '' %>" href="/products/mine"><%= __('nav.mine') %></a>
              <button class="nav-button" id="themeToggle" title="<%= __('toggle.theme') %>">🌙</button>
              <button class="nav-button" id="langToggle" title="<%= __('toggle.lang') %>"><%= (lang === 'en') ? '中' : 'EN' %></button>
          <form class="inline-form" action="/logout" method="POST">
            <button class="nav-button" type="submit">
              <%= currentUser.username %> 退出
            </button>
          </form>
          <!-- Codex, GPT-5.5 High, OpenAI. -->
          <form class="inline-form" action="/delete-account" method="POST" onsubmit="return confirm('确定要注销账户吗？你的在售商品将下架，此操作不可恢复。')">
            <button class="nav-button danger-link" type="submit">注销账户</button>
          </form>
          <!-- end: Codex, GPT-5.5 High, OpenAI. -->
          <% } else { %>
            <a class="<%= active === 'login' ? 'active' : '' %>" href="/login"><%= __('nav.login') %></a>
            <a class="nav-strong <%= active === 'register' ? 'active' : '' %>" href="/register"><%= __('nav.register') %></a>
            <% } %>
      </nav>
    </div>
  </header>
  <!-- Antigraity, Gemini 3.1 Pro (high), Google. -->
  <% if (typeof flashMsg !== 'undefined' && flashMsg) { %>
    <div class="flash-toast">
      <%= flashMsg %>
    </div>
  <% } %>
  <!-- end: Antigraity, Gemini 3.1 Pro (high), Google. -->
  <main class="page-shell">
    <!-- end: Codex, GPT-5.5 High, OpenAI. -->
