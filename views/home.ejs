<!-- Codex, GPT-5.5 High, OpenAI. -->
<%- include('partials/header', { title, active, currentUser }) %>

  <section class="storefront">
    <aside class="filter-panel">
      <p class="eyebrow" data-i18n="nav.home"><%= __('nav.home') %></p>
      <h1>Cream Market</h1>
      <%- include('partials/product-filters', { query, categories, formAction: '/', mode: 'home' }) %>
    </aside>

    <section class="product-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow" data-i18n="nav.home"><%= __('nav.home') %></p>
          <h2>全部商品</h2>
        </div>
        <div class="heading-actions">
          <span class="result-count">
            <%= products.length %> 件商品
          </span>
          <a class="text-link" href="/products/new">发布商品</a>
        </div>
      </div>

      <% if (products.length===0) { %>
        <div class="empty-state">暂时没有符合条件的商品。</div>
        <% } %>

          <div class="product-grid">
            <% products.forEach(product=> { %>
              <%- include('partials/product-card', { product }) %>
                <% }) %>
          </div>
    </section>
  </section>

  <%- include('partials/footer') %>
    <!-- end: Codex, GPT-5.5 High, OpenAI. -->