<%- include('../partials/header', { title, active, currentUser }) %>

<style>
  :root{--pri:#50a3a2}
  .wrapper{background:linear-gradient(135deg,#50a3a2 0%,#53e3a6 100%);position:fixed;inset:0;display:flex;align-items:center;justify-content:center;overflow:hidden;z-index:0}
  .glow{position:absolute;border-radius:50%;filter:blur(80px);pointer-events:none;z-index:0}
  .glow-1{width:360px;height:360px;background:rgba(83,227,166,.18);top:-120px;right:-80px}
  .glow-2{width:260px;height:260px;background:rgba(255,255,255,.08);bottom:-60px;left:-60px}
  .bg-bubbles{position:absolute;inset:0;z-index:1;pointer-events:none}
  .bg-bubbles li{position:absolute;list-style:none;display:block;background-color:rgba(255,255,255,.12);bottom:-220px;border-radius:50%;animation:rise 25s infinite linear}
  @keyframes rise{0%{transform:translateY(0) rotate(0deg)}100%{transform:translateY(-750px) rotate(600deg)}}
  .container{position:relative;z-index:2;max-width:760px;width:92%;padding:36px;background:rgba(255,255,255,0.98);border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,.12)}
  .auth-grid{display:flex;gap:36px;align-items:center}
  .auth-copy{flex:1}
  .auth-copy h1{margin:0 0 8px;font-size:28px;color:#0b0f10}
  .auth-copy p{color:#445}
  .auth-form{flex:1}
  .auth-form label{display:block;margin-bottom:12px}
  .auth-form input{width:100%;padding:10px;border:1px solid #e6e6e8;border-radius:6px}
  .message{background:#ffecec;color:#900;padding:10px;border-radius:6px;margin-bottom:12px}
  .button.primary{background:var(--pri);color:#fff;border:0;padding:10px 14px;border-radius:6px;cursor:pointer}
  .hint{font-size:12px;color:#666;margin-top:6px}
</style>

<div class="wrapper" id="regWrapper">
  <div class="glow glow-1"></div>
  <div class="glow glow-2"></div>
  <ul class="bg-bubbles"><li></li><li></li><li></li><li></li><li></li><li></li><li></li><li></li><li></li><li></li></ul>

  <div class="container">
    <div class="auth-grid">
      <div class="auth-copy">
        <h1>创建你的账号</h1>
        <p>请填写下列信息完成注册。注册后会自动登录并跳转到首页。</p>
      </div>

      <form class="auth-form" action="/register" method="POST">
          <h1 data-i18n="auth.registerTitle"><%= __('auth.registerTitle') %></h1>
          <% if (typeof message !== 'undefined' && message) { %>
            <div class="message"><%= message %></div>
          <% } %>
          <label>
            用户名
            <input required type="text" name="username" value="<%= typeof username !== 'undefined' ? username : '' %>">
          </label>
          <label>
            邮箱
            <input required type="email" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">
          </label>
          <label>
            密码
            <input type="password" name="password" id="passwordInput" required>
            <div class="hint" id="passwordHint">密码需为 8-20 位，包含大小写字母和数字。</div>
            <ul class="password-rules" style="list-style:none;padding:0;margin-top:4px;font-size:13px;">
              <li id="ruleLength">8-20 位字符</li>
              <li id="ruleUpper">至少一个大写字母</li>
              <li id="ruleLower">至少一个小写字母</li>
              <li id="ruleDigit">至少一个数字</li>
            </ul>
          </label>
          <label>
            验证码
            <div style="display:flex;gap:8px;align-items:center">
              <input required type="text" name="captcha" placeholder="输入图中字符" style="flex:1">
              <img id="captchaImage" src="/captcha" style="height:44px;border:1px solid #ddd;border-radius:6px;cursor:pointer" title="点击刷新">
            </div>
          </label>
          <button class="button primary" type="submit">注册并登录</button>
          <div style="margin-top:12px"><a href="/login" data-i18n="auth.loginTitle"><%= __('auth.loginTitle') %></a></div>
        </form>
    </div>
  </div>
</div>

<script>
;(function(){
  const g1 = document.querySelector('#regWrapper .glow-1');
  const g2 = document.querySelector('#regWrapper .glow-2');
  if(!g1 || !g2) return;
  document.addEventListener('mousemove', e=>{
    const x = (e.clientX/window.innerWidth - 0.5) * 40;
    const y = (e.clientY/window.innerHeight - 0.5) * 40;
    g1.style.transform = `translate(${x}px,${y}px)`;
    g2.style.transform = `translate(${ -x*0.6 }px,${ -y*0.6 }px)`;
  }, {passive:true});
})();
</script>

<%- include('../partials/footer') %>
