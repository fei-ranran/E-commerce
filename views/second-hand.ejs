<!-- Codex, GPT-5.5 High, OpenAI. -->
<%- include('partials/header', { title, active, currentUser }) %>

  <section class="storefront second-layout">
    <aside class="filter-panel">
      <p class="eyebrow">Second-hand</p>
      <h1>二手交易</h1>
      <%- include('partials/product-filters', { query, categories, formAction: '/second-hand', mode: 'second' }) %>
    </aside>

    <section class="product-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Used Items</p>
          <h2>二手专区</h2>
        </div>
        <div class="heading-actions">
          <span class="result-count">
            <%= products.length %> 件商品
          </span>
          <a class="text-link" href="/products/new">我要转卖</a>
        </div>
      </div>

      <% if (products.length===0) { %>
        <div class="empty-state">暂时没有符合条件的二手商品。</div>
        <% } %>

          <div class="product-grid">
            <% products.forEach(product=> { %>
              <%- include('partials/product-card', { product }) %>
                <% }) %>
          </div>
    </section>
  </section>

  <%- include('partials/footer') %>
    <!-- end: Codex, GPT-5.5 High, OpenAI. -->