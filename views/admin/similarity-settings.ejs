<%- include('../partials/header', { title, active, currentUser }) %>

<section class="manage-page">
  <div class="section-heading wide">
    <div>
      <p class="eyebrow">Admin</p>
      <h1 data-i18n="admin.similarity.title"><%= __('admin.similarity.title') %></h1>
    </div>
  </div>

  <form class="app-form" action="/admin/similarity-settings" method="POST">
    <% if (typeof message !== 'undefined' && message) { %>
      <p class="message"><%= message %></p>
    <% } %>
    <label>
      相似度阈值（0.50 - 0.99）
      <input
        type="number"
        name="duplicateSimilarityThreshold"
        min="0.5"
        max="0.99"
        step="0.01"
        value="<%= Number(value || 0.78).toFixed(2) %>"
        required>
    </label>
    <p class="form-hint">值越高，判定“重复”的条件越严格。推荐 0.75~0.85。</p>
    <div class="action-row">
      <button class="button primary" type="submit" data-i18n="admin.similarity.save"><%= __('admin.similarity.save') %></button>
      <a class="button ghost" href="/" data-i18n="admin.similarity.back"><%= __('admin.similarity.back') %></a>
    </div>
  </form>
</section>

<%- include('../partials/footer') %>
