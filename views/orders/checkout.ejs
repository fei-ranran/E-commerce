<!-- Codex, GPT-5.5 High, OpenAI. -->
<%- include('../partials/header', { title, active, currentUser }) %>

  <section class="checkout-layout">
    <div class="form-copy">
      <p class="eyebrow" data-i18n="checkout.title"><%= __('checkout.title') %></p>
      <h1 data-i18n="checkout.title"><%= __('checkout.title') %></h1>
    </div>

    <form class="app-form" action="/orders" method="POST">
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="message">
          <%= message %>
        </div>
      <% } %>
      <label>
        <span data-i18n="checkout.receiver"><%= __('checkout.receiver') %></span>
        <input required type="text" name="customerName" value="<%= currentUser ? currentUser.username : '' %>">
      </label>
      <label>
        <span data-i18n="checkout.phone"><%= __('checkout.phone') %></span>
        <input required type="text" name="phone">
      </label>
      <label>
        <span data-i18n="checkout.address"><%= __('checkout.address') %></span>
        <textarea required name="address" rows="4"></textarea>
      </label>
      <button class="button primary full" type="submit" data-i18n="checkout.submit"><%= __('checkout.submit') %></button>
    </form>

    <aside class="order-summary">
      <h2>订单摘要</h2>
      <% cart.items.forEach(item=> { %>
        <div class="summary-row">
          <span>
            <%= item.product.name %> × <%= item.quantity %>
          </span>
          <strong>¥<%= item.subtotal.toFixed(2) %></strong>
        </div>
        <% }) %>
          <div class="summary-total">
            <span>合计</span>
            <strong>¥<%= cart.total.toFixed(2) %></strong>
          </div>
    </aside>
  </section>

  <%- include('../partials/footer') %>
    <!-- end: Codex, GPT-5.5 High, OpenAI. -->
