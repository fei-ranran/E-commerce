<!-- Codex, GPT-5.5 High, OpenAI. -->
<%- include('../partials/header', { title, active, currentUser }) %>

<section class="manage-page">
  <div class="section-heading wide">
    <div>
      <p class="eyebrow" data-i18n="nav.orders"><%= __('nav.orders') %></p>
      <h1 data-i18n="orders.title"><%= __('orders.title') %></h1>
    </div>
    <span class="result-count"><%= typeof orders !== 'undefined' ? orders.length : 0 %> <span data-i18n="orders.count">笔订单</span></span>
  </div>

  <% if (typeof orders === 'undefined' || orders.length === 0) { %>
    <div class="empty-state">
      <p data-i18n="orders.empty"><%= __('orders.empty') %></p>
      <a class="button primary" href="/" data-i18n="orders.browse"><%= __('orders.browse') %></a>
    </div>
  <% } %>

  <div class="order-list">
    <% orders.forEach(order => { %>
      <article class="order-card">
        <div class="order-card-head">
          <div class="order-card-meta">
            <span class="order-id" data-i18n="order.orderIdLabel"><%= __('order.orderIdLabel') %> <code><%= order._id %></code></span>
            <span class="order-time"><%= order.createdAt.toLocaleString('zh-CN') %></span>
          </div>
          <span class="order-status-badge"><%= order.status %></span>
        </div>

        <div class="order-items-preview">
          <% order.items.forEach(item => { %>
            <div class="order-item-row">
              <span class="order-item-name"><%= item.name %></span>
              <span class="order-item-cond <%= item.condition %>"><%= item.condition === 'used' ? '二手' : '新品' %></span>
              <span class="order-item-qty">× <%= item.quantity %></span>
              <span class="order-item-price">¥<%= item.price.toFixed(2) %></span>
            </div>
          <% }) %>
        </div>

        <div class="order-card-foot">
          <span class="order-total" data-i18n="order.paidLabel"><%= __('order.paidLabel') %> <strong>¥<%= order.total.toFixed(2) %></strong></span>
          <div class="order-inline-actions">
            <% if (order.status !== '已完成') { %>
              <form action="/orders/<%= order._id %>/confirm-received" method="POST">
                <button class="button primary" type="submit" data-i18n="order.confirmReceived"><%= __('order.confirmReceived') %></button>
              </form>
            <% } else if (order.reviewMeta && order.reviewMeta.reviewOpen) { %>
              <a class="button secondary" href="/orders/<%= order._id %>" data-i18n="order.goToReview"><%= __('order.goToReview') %></a>
            <% } else if (order.reviewMeta && order.reviewMeta.reviewExpired) { %>
              <span class="order-review-closed" data-i18n="order.reviewClosed"><%= __('order.reviewClosed') %></span>
            <% } %>
            <a class="button ghost" href="/orders/<%= order._id %>" data-i18n="order.viewDetails"><%= __('order.viewDetails') %></a>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<%- include('../partials/footer') %>
<!-- end: Codex, GPT-5.5 High, OpenAI. -->
