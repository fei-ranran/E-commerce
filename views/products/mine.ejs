<!-- Codex, GPT-5.5 High, OpenAI. -->
<%- include('../partials/header', { title, active, currentUser }) %>

<section class="manage-page">
  <div class="section-heading wide">
    <div>
      <p class="eyebrow">Manage</p>
      <h1>我的发布</h1>
    </div>
    <div>
      <a class="button primary" href="/products/new">发布商品</a>
      <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'superadmin')) { %>
        <a class="button" href="/admin/users">用户管理</a>
      <% } %>
    </div>
  </div>

  <% if (typeof sellerDashboard !== 'undefined' && sellerDashboard) { %>
    <section class="seller-dashboard-panel">
      <div class="seller-dashboard-grid">
        <div><span>在售商品</span><strong><%= sellerDashboard.productsCount || 0 %></strong></div>
        <div><span>平均评分</span><strong><%= Number(sellerDashboard.averageRating || 0).toFixed(2) %></strong></div>
        <div><span>好评率</span><strong><%= Number(sellerDashboard.goodRate || 0).toFixed(2) %>%</strong></div>
        <div><span>交易成功率</span><strong><%= Number(sellerDashboard.successRate || 0).toFixed(2) %>%</strong></div>
      </div>
    </section>
  <% } %>

  <% if (products.length === 0) { %>
    <div class="empty-state">
      <p>你还没有发布商品。</p>
      <a class="button primary" href="/products/new">去发布</a>
    </div>
  <% } else { %>
    <div class="manage-list">
      <% products.forEach(product => { %>
        <article class="manage-item">
          <a class="manage-media" href="/products/<%= product._id %>">
            <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
          </a>
          <div class="manage-content">
            <div>
              <h3><a href="/products/<%= product._id %>"><%= product.name %></a></h3>
              <p><%= product.description %></p>
            </div>
            <div class="product-meta">
              <span><%= product.condition === 'used' ? '二手' : '新品' %></span>
              <% var wearLabels = { like_new: '几乎全新', good: '良好', fair: '一般', visible_wear: '明显痕迹' }; %>
              <% if (product.condition === 'used' && product.wearGrade) { %>
                <span class="wear-chip"><%= wearLabels[product.wearGrade] || product.wearGrade %></span>
              <% } %>
              <% if (product.freeShipping) { %><span class="shipping-badge">包邮</span><% } %>
              <span><%= product.category %></span>
              <span>已售 <%= product.salesCount != null ? product.salesCount : 0 %></span>
              <span>库存 <%= product.stock %></span>
            </div>
          </div>
          <strong class="manage-price">¥<%= product.price.toFixed(2) %></strong>
          <div class="manage-actions">
            <a class="button secondary" href="/products/<%= product._id %>/edit">编辑</a>
            <a class="button ghost" href="/products/<%= product._id %>/messages">消息 (<%= messageCounts && messageCounts[product._id] ? messageCounts[product._id] : 0 %>)</a>
            <form action="/products/<%= product._id %>?_method=DELETE" method="POST">
              <button class="button danger" type="submit">删除</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
