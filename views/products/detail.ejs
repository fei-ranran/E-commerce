<!-- Codex, GPT-5.5 High, OpenAI. -->
<%- include('../partials/header', { title, active, currentUser }) %>

<section class="detail-layout">
  <div class="detail-media">
    <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
    <span class="condition-badge <%= product.condition === 'used' ? 'used' : 'new' %>">
      <%= product.condition === 'used' ? '二手' : '新品' %>
    </span>
  </div>
  <div class="detail-panel">
    <p class="eyebrow"><%= product.category %></p>
    <h1><%= product.name %></h1>
    <p class="detail-description"><%= product.description %></p>
    <div class="price-line">¥<%= product.price.toFixed(2) %></div>
    <dl class="info-list">
      <div><dt>卖家</dt><dd><%= product.sellerName %></dd></div>
      <div><dt>库存</dt><dd><%= product.stock %></dd></div>
      <div><dt>标签</dt><dd><%= product.tags && product.tags.length ? product.tags.join(' / ') : '无' %></dd></div>
    </dl>
    <div class="action-row">
      <!-- Antigraity, Gemini 3.1 Pro (high), Google.：库存为0时显示已售罄 -->
      <% if (product.stock > 0) { %>
        <form action="/cart/add/<%= product._id %>" method="POST">
          <button class="button primary" type="submit">加入购物车</button>
        </form>
      <% } else { %>
        <button class="button ghost" disabled>已售罄</button>
      <% } %>
      <!-- end: Antigraity, Gemini 3.1 Pro (high), Google. -->
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
